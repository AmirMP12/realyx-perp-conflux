apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: realyx
type: Opaque
stringData:
  # Primary Postgres connection (the indexer worker writes here; the API also
  # falls back to this when no read replica is configured).
  POSTGRES_URL: "postgres://realyx:CHANGE_ME@postgres:5432/realyx"
  # Optional read replica for API read traffic. Falls back to POSTGRES_URL when unset.
  POSTGRES_READ_URL: ""
  # Secret used to authenticate the cron-triggered /api/sync endpoint.
  CRON_SECRET: ""
  # Bearer secret the keeper-bot must present to POST /api/v1/keeper/failure.
  KEEPER_WEBHOOK_SECRET: ""
  # Secret guarding the /api/debug endpoint in production (Bearer or ?key=).
  DEBUG_SECRET: ""
  # Optional: add keys when backend supports them
  # REDIS_URL: ""
