{
  "name": "realyx",
  "version": "1.0.0",
  "description": "Realyx - RWA Perpetual Futures DEX. Trade with leverage.",
  "author": "Realyx",
  "license": "MIT",
  "keywords": [
    "perpetuals",
    "defi",
    "rwa",
    "conflux",
    "solidity",
    "hardhat"
  ],
  "scripts": {
    "compile": "hardhat compile && node scripts/fix-abi-enums.js",
    "compile:force": "hardhat compile --force && node scripts/fix-abi-enums.js",
    "clean": "hardhat clean",
    "export-abi": "node scripts/export-abi.js",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "test:gas": "REPORT_GAS=true hardhat test",
    "lint": "node node_modules/prettier/bin/prettier.cjs \"contracts/**/*.sol\" \"scripts/**/*.ts\" --check",
    "lint:fix": "node node_modules/prettier/bin/prettier.cjs \"contracts/**/*.sol\" \"scripts/**/*.ts\" --write",
    "deploy:local": "hardhat run scripts/deploy-testnet.ts --network localhost",
    "deploy:hardhat": "hardhat run scripts/deploy-testnet.ts --network hardhat",
    "deploy:conflux": "hardhat run scripts/deploy-mainnet.ts --network conflux",
    "deploy:conflux-testnet": "hardhat run scripts/deploy-testnet.ts --network confluxTestnet",
    "verify:conflux-testnet": "hardhat run scripts/verify.ts --network confluxTestnet",
    "verify:mockusdc": "hardhat run scripts/verify-mockusdc.ts --network confluxTestnet",
    "verify:conflux": "hardhat run scripts/verify.ts --network conflux",
    "setup:collection": "hardhat run scripts/setup-collection.ts",
    "setup:market": "hardhat run scripts/setup-market.ts --network confluxTestnet",
    "update:market": "hardhat run scripts/update-market.ts --network confluxTestnet",
    "unlist:market": "hardhat run scripts/unlist-market.ts --network confluxTestnet",
    "grant:role": "hardhat run scripts/grant-operator.ts --network confluxTestnet",
    "node": "hardhat node",
    "typechain": "hardhat compile && node scripts/fix-abi-enums.js && hardhat typechain",
    "infra:graph:up": "docker compose -f docker-compose.graph.yml up -d",
    "infra:graph:down": "docker compose -f docker-compose.graph.yml down",
    "infra:graph:logs": "docker compose -f docker-compose.graph.yml logs -f",
    "backend:dev": "cd backend && npm run dev",
    "backend:build": "cd backend && npm run build",
    "backend:test": "cd backend && npm test"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.2.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@pythnetwork/pyth-sdk-solidity": "^4.2.0",
    "cors": "^2.8.5",
    "ethers": "^6.13.0",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "graphql-request": "^7.0.0",
    "helmet": "^7.1.0",
    "pino": "^9.4.0",
    "pino-http": "^10.2.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.11",
    "@openzeppelin/hardhat-upgrades": "^3.5.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.1.0",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.16",
    "hardhat-gas-reporter": "^1.0.10",
    "mocha": "^10.2.0",
    "prettier": "^3.1.1",
    "prettier-plugin-solidity": "^1.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
