# ============================================
# REQUIRED — Deployment Account
# ============================================

# Private key for deployment (without 0x prefix)
PRIVATE_KEY=

# Alternative: Use mnemonic phrase instead of private key
# MNEMONIC=

# ============================================
# RPC URLs — Network Endpoints
# ============================================

# Conflux eSpace
CONFLUX_RPC_URL=https://evm.confluxrpc.com
# Must match hardhat.config.ts default (see CONFLUX_TESTNET_RPC_URL there)
CONFLUX_TESTNET_RPC_URL=https://evmtestnet.confluxrpc.com
# Deploy/network RPC request timeout in milliseconds (default in config: 900000)
# DEPLOY_RPC_TIMEOUT_MS=900000
CONFLUXSCAN_API_KEY=

# ============================================
# Contract Deployment — Addresses
# ============================================

# Treasury address for protocol fees (required for mainnet)
TREASURY_ADDRESS=

# USDT0 token address — main settlement collateral (optional — uses network defaults; set to skip MockUSDT0 on testnet)
# USDT0_ADDRESS=

# Pyth contract address (optional — each network has a default; override here if needed)
# PYTH_ADDRESS=

# ============================================
# Post-Deployment Addresses
# Used by: verify.ts, setup-market.ts, update-market.ts,
#          unlist-market.ts, grant-operator.ts
# ============================================
# If these are empty, verify.ts will auto-read from deployment/<network>.json.
# Override after your own deploy, or leave empty to use the deployment JSON.

# deployment/confluxTestnet.json (2026-06-21)
DEPLOYED_ORACLE_AGGREGATOR=0x9d027ab66F396176C188946cE49BA9061679e6a9
DEPLOYED_VAULT_CORE=0x98E011A8782aF36C5Ad6051bC54B86a7c0705F67
DEPLOYED_POSITION_TOKEN=0xF520CC4B305553A9b6D391571c303E45AacC178c
DEPLOYED_TRADING_CORE=0xc8A6585dFBe2833ed093E557D36DC8Fe136a8c76
DEPLOYED_MARKET_CALENDAR=0xDE6a4fa0e8DE4D3f0792010Fd49AbdeF8915529e
DEPLOYED_DIVIDEND_MANAGER=0xA84104C6E2Ed7455a606A3439aF80863112e9B0b
DEPLOYED_COMPLIANCE_MANAGER=0xD694F0BC86e1f24439037A221f7c4e3beDB781D7
DEPLOYED_DIVIDEND_KEEPER=0x5CCdb637C1Fa5D06D7F666BDBb62F3Ad12A58010
DEPLOYED_TRADING_CORE_VIEWS=0xb5c01fb09F2B9f62A4907dDB41c216419e79AbC5
DEPLOYED_MOCK_USDT0=0x85B9BA60D6Aef728c0Ea9C9f6709D31707dfC73A
# Multi-collateral, copy-trading, and referral registries (set after deploy):
DEPLOYED_COLLATERAL_REGISTRY=0x0f5cAC8a3BC4E61ABA1d547D9A2C1DFA5A087054
DEPLOYED_COPY_REGISTRY=0xf09b2fa210Fe2dbE17287B331E7A93c58Bb5A001
DEPLOYED_REFERRAL_REGISTRY=0x5FbD3aBfBdB667e543B23B80f34Fa7167C1514a8
# When deploy uses MockPyth (no PYTH_ADDRESS on network):
# DEPLOYED_MOCK_PYTH=0x...

# ============================================
# Upgrade Script (upgrade.ts)
# ============================================
# npm run upgrade:conflux-testnet

# TradingCore only: bytecode links these libraries (deploy fresh libs, then set env):
# LIB_TRADING_LIB=0x...
# LIB_CLEANUP_LIB=0x...
# LIB_CONFIG_LIB=0x...
# LIB_DUST_LIB=0x...
# LIB_FLASH_LOAN_CHECK=0x...
# LIB_FUNDING_LIB=0x...
# LIB_HEALTH_LIB=0x...
# LIB_POSITION_TRIGGERS_LIB=0x...
# LIB_RATE_LIMIT_LIB=0x...
# LIB_TRADING_CONTEXT_LIB=0x...
# LIB_WITHDRAW_LIB=0x...
# OracleAggregator / TradingCoreViews use internal libs only — no LIB_* vars for those upgrades.

# ============================================
# Market Setup (setup-market.ts)
# ============================================
# Single market:
#   MARKET_ADDRESS=0x...
#   PYTH_FEED_ID=0x...
#   MARKET_ID=optional
#
# Multiple markets (comma-separated; same count for addresses and feed IDs):
#   MARKET_ADDRESSES=0x...,0x...
#   PYTH_FEED_IDS=0x...,0x...
#   MARKET_IDS=id1,id2   (optional, one per market)
#
# Shared for all markets:
# MARKET_ADDRESS=0x...
# PYTH_FEED_ID=0x...
# MARKET_ADDRESSES=0x986a...,0x886a...
# PYTH_FEED_IDS=0xe62df6...,0xff6149...
# MARKET_ID=
# MARKET_IDS=
# MAX_LEVERAGE=50
# MAX_POSITION_SIZE=100000000000000000000000
# MAX_EXPOSURE=50000000000000000000000000
# MAINTENANCE_MARGIN_BPS=500
# INITIAL_MARGIN_BPS=1000
# MAX_STALENESS=900
# Per-feed Pyth confidence cap (absolute, normalized to 18 decimals, uint64).
# setPythFeed rejects 0 (MaxConfidenceRequired); must be <= 18446744073709551615.
# Default = uint64 max (most permissive). Single value or comma-separated list.
# MAX_CONFIDENCE=18446744073709551615

# Update existing market (update-market.ts):
# MARKET_ADDRESS=0x...  PYTH_FEED_ID=0x...  MARKET_ID=...  MAX_LEVERAGE=20  etc.

# Unlist market (unlist-market.ts) — frees a slot:
# MARKET_ADDRESS=0x...   or   UNLIST_MARKET_ADDRESS=0x...

# Generate a deterministic market address:
#   npm run market:address -- TSLA

# ============================================
# Grant OPERATOR_ROLE (grant-operator.ts)
# ============================================
# GRANT_TO_ADDRESS=0x...  (defaults to deployer signer)
# Used by grant-keeper-role.ts as well.

# ============================================
# Register Collaterals (register-collaterals.ts)
# ============================================
# COLLATERAL_REGISTRY=0x...           # deployed CollateralRegistry address
# USDC_ADDRESS=0x...                  # alt collateral token (6 decimals)
# USDC_PRICE_FEED=0x...               # OracleAggregator market used to price USDC
# AXCNH_ADDRESS=0x...                 # alt collateral token (18 decimals)
# AXCNH_PRICE_FEED=0x...              # OracleAggregator market used to price AxCNH

# ============================================
# Referral Registry defaults (deploy.ts)
# ============================================
# Default fee discount/rebate (bps) applied before any tier qualifies.
# REFERRAL_DEFAULT_DISCOUNT_BPS=500   # 5% discount to referee
# REFERRAL_DEFAULT_REBATE_BPS=1000    # 10% rebate to referrer

# ============================================
# Auto Keeper Bot (scripts/keeper-bot.ts)
# ============================================
# Optional override; defaults to HARDHAT_NETWORK or "confluxTestnet"
# KEEPER_NETWORK=confluxTestnet
# Defaults to CONFLUX_TESTNET_RPC_URL/CONFLUX_RPC_URL if not set
# KEEPER_RPC_URL=https://evmtestnet.confluxrpc.com
# Optional CSV fallback endpoints (bot rotates on timeout/rate limit).
# If unset, the bot auto-adds the Conflux .org mirror for known .com URLs.
# KEEPER_RPC_URLS=https://evmtestnet.confluxrpc.com,https://evmtestnet.confluxrpc.org
# Retry attempts per RPC call before giving up
# KEEPER_RPC_MAX_ATTEMPTS=3
# Hermes endpoint base URL for Pyth updates
# KEEPER_HERMES_URL=https://hermes.pyth.network
# Private key for keeper wallet (falls back to PRIVATE_KEY)
# KEEPER_PRIVATE_KEY=
# Defaults to DEPLOYED_TRADING_CORE or deployment/<network>.json
# KEEPER_TRADING_CORE_ADDRESS=0x...
# Poll loop interval when orders are pending (seconds). Use 8–15+ on public RPC.
# KEEPER_POLL_INTERVAL_SECONDS=5
# Slower poll when idle (no pending orders) to conserve daily RPC quota.
# KEEPER_IDLE_POLL_INTERVAL_SECONDS=15
# How many historical blocks to backfill at startup
# KEEPER_LOOKBACK_BLOCKS=20000
# Chunk size for getLogs scanning
# KEEPER_BLOCK_CHUNK_SIZE=4000
# Minimum interval between price refreshes for same market
# KEEPER_MIN_PRICE_REFRESH_SECONDS=20

# ============================================
# Frontend Build Args (docker-compose / Railway) — see also frontend/.env.example
# ============================================
# VITE_RPC_URL=https://evmtestnet.confluxrpc.com
# VITE_CONFLUX_TESTNET_RPC_URL=https://evmtestnet.confluxrpc.com
# VITE_APP_URL=https://your-app.example   (optional; WalletConnect / metadata)
# VITE_API_URL=/api
# VITE_WS_URL=                # empty = REST polling mode (recommended on Railway)
# VITE_WS_URL=ws://localhost:3000/ws  # local/docker websocket
# VITE_WALLET_CONNECT_PROJECT_ID=
# VITE_POSITION_TOKEN_ADDRESS=0xF520CC4B305553A9b6D391571c303E45AacC178c
# VITE_ORACLE_AGGREGATOR_ADDRESS=0x9d027ab66F396176C188946cE49BA9061679e6a9
# VITE_VAULT_CORE_ADDRESS=0x98E011A8782aF36C5Ad6051bC54B86a7c0705F67
# VITE_TRADING_CORE_ADDRESS=0xc8A6585dFBe2833ed093E557D36DC8Fe136a8c76
# VITE_MOCK_USDT0_ADDRESS=0x85B9BA60D6Aef728c0Ea9C9f6709D31707dfC73A

# ============================================
# NPM scripts (run from repository root; see package.json)
# ============================================
# ABIs:  npm run contracts:sync   — hardhat compile + export ABIs to backend/src/abi & frontend/src/abi
#        npm run export-abi      — export only (expects artifacts present)
#        npm run sync:frontend-abi — copy TradingCore/VaultCore/OracleAggregator JSON to frontend
# Build: npm run compile | compile:force
# Apps:  npm run backend:dev | frontend:dev | backend:typecheck | frontend:typecheck
# Infra: npm run infra:up | infra:up:full | infra:down  (Windows: scripts/docker-up.ps1)

# ============================================
# Development & Testing
# ============================================

# Enable gas reporting
REPORT_GAS=false

# CoinMarketCap API for USD gas estimates
COINMARKETCAP_API_KEY=

# Skip confirmation prompts for mainnet deployment
# SKIP_CONFIRMATIONS=false

# Override gas price (gwei) for deploy/scripts if "replacement transaction underpriced"
# Example: GAS_PRICE_GWEI=25
# GAS_PRICE_GWEI=

# ── Oracle Configuration & Price Update Controls ──────────────────────────────
# Used by: scripts/set-oracle-config.ts and scripts/update-prices.ts
#
# ORACLE_SET=true                     # Set to true to apply oracle feed config changes on-chain
# ORACLE_MARKETS=0x...,0x...          # Restrict config/update to specific market addresses (comma-separated)
# ORACLE_AUTO=true                    # Auto-size maxConfidence from live feed bps * multiplier
# ORACLE_MAX_CONFIDENCE_MULTIPLIER=3  # Multiplier used when ORACLE_AUTO=true (default: 3)
# ORACLE_MAX_CONFIDENCE=100           # Explicit relative confidence cap in basis points (overrides defaults)
# ORACLE_MAX_STALENESS=900            # Override max staleness in seconds for all markets (default: 900)
# ORACLE_AGGREGATOR_ADDRESS=0x...     # Override deployed OracleAggregator contract address


