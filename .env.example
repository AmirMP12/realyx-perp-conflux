# ============================================
# REQUIRED — Deployment Account
# ============================================

# Private key for deployment (without 0x prefix)
PRIVATE_KEY=

# Alternative: Use mnemonic phrase instead of private key
# MNEMONIC=

# ============================================
# RPC URLs — Network Endpoints
# ============================================

# Conflux eSpace
CONFLUX_RPC_URL=https://evm.confluxrpc.com
CONFLUX_TESTNET_RPC_URL=https://evmtestnet.confluxrpc.com
# Deploy/network RPC request timeout in milliseconds (default in config: 900000)
# DEPLOY_RPC_TIMEOUT_MS=900000
CONFLUXSCAN_API_KEY=

# ============================================
# Contract Deployment — Addresses
# ============================================

# Treasury address for protocol fees (required for mainnet)
TREASURY_ADDRESS=

# USDC token address (optional — uses network defaults; set to skip MockUSDC on testnet)
# USDC_ADDRESS=

# Pyth contract address (optional — each network has a default; override here if needed)
# PYTH_ADDRESS=

# ============================================
# Post-Deployment Addresses
# Used by: verify.ts, setup-market.ts, update-market.ts,
#          unlist-market.ts, grant-operator.ts
# ============================================
# If these are empty, verify.ts will auto-read from deployment/<network>.json.
# Override after your own deploy, or leave empty to use the deployment JSON.

DEPLOYED_ORACLE_AGGREGATOR=0xBb9B26F89624a505Fc4318463CC5a7325E5A106E
DEPLOYED_VAULT_CORE=0xe934aB1736a7924c1B9A290d57a73a0340092e24
DEPLOYED_POSITION_TOKEN=0x0e7110ED111add8Ac5EB148567f4504569aC749f
DEPLOYED_TRADING_CORE=0x49493c04Df243FDD73a26E0AB10d9Fd89d82a92e
DEPLOYED_MARKET_CALENDAR=0xAce65988553110839a3aa06E5b6ac9292A88dC2e
DEPLOYED_DIVIDEND_MANAGER=0xCDb1F9204Bd797d26974517a324CBc31E7BBEB32
DEPLOYED_COMPLIANCE_MANAGER=0x3a3D6b28a8212865dbF9ccA458DD320A2AF6E8e8
DEPLOYED_DIVIDEND_KEEPER=0xE88C8A83eA963837D8C3Af5F98169515C070e51f
DEPLOYED_TRADING_CORE_VIEWS=0x5AEA00500f4b7519DeA151bC1590496ABAAb4B15
DEPLOYED_MOCK_USDC=0x4d0874577f1E6326E75EbBAf2F73C548B3ec32F1

# ============================================
# Upgrade Script (upgrade.ts)
# ============================================
# npm run upgrade:conflux-testnet

# CONTRACT_TO_UPGRADE=VaultCore
# PROXY_ADDRESS=0x...

# For linked-library contracts, also set the library addresses:
# LIB_TRADING_LIB=0x...
# LIB_CLEANUP_LIB=0x...
# LIB_CONFIG_LIB=0x...
# LIB_DUST_LIB=0x...
# LIB_FLASH_LOAN_CHECK=0x...
# LIB_FUNDING_LIB=0x...
# LIB_HEALTH_LIB=0x...
# LIB_POSITION_TRIGGERS_LIB=0x...
# LIB_TRADING_CONTEXT_LIB=0x...
# LIB_WITHDRAW_LIB=0x...
# LIB_CIRCUIT_BREAKER_LIB=0x...
# LIB_EMERGENCY_PAUSE_LIB=0x...
# LIB_EMERGENCY_PRICE_LIB=0x...
# LIB_POSITION_MATH=0x...

# ============================================
# Market Setup (setup-market.ts)
# ============================================
# Single market:
#   MARKET_ADDRESS=0x...
#   PYTH_FEED_ID=0x...
#   MARKET_ID=optional
#
# Multiple markets (comma-separated; same count for addresses and feed IDs):
#   MARKET_ADDRESSES=0x...,0x...
#   PYTH_FEED_IDS=0x...,0x...
#   MARKET_IDS=id1,id2   (optional, one per market)
#
# Shared for all markets:
# MARKET_ADDRESS=0x...
# PYTH_FEED_ID=0x...
# MARKET_ADDRESSES=0x986a...,0x886a...
# PYTH_FEED_IDS=0xe62df6...,0xff6149...
# MARKET_ID=
# MARKET_IDS=
# MAX_LEVERAGE=50
# MAX_POSITION_SIZE=100000000000000000000000
# MAX_EXPOSURE=50000000000000000000000000
# MAINTENANCE_MARGIN_BPS=500
# INITIAL_MARGIN_BPS=1000
# MAX_STALENESS=900

# Update existing market (update-market.ts):
# MARKET_ADDRESS=0x...  PYTH_FEED_ID=0x...  MARKET_ID=...  MAX_LEVERAGE=20  etc.

# Unlist market (unlist-market.ts) — frees a slot:
# MARKET_ADDRESS=0x...   or   UNLIST_MARKET_ADDRESS=0x...

# Generate a deterministic market address:
#   npm run market:address -- TSLA

# ============================================
# Grant OPERATOR_ROLE (grant-operator.ts)
# ============================================
# GRANT_TO_ADDRESS=0x...  (defaults to deployer signer)

# ============================================
# Graph Node / Subgraph
# ============================================
# Used by docker-compose.graph.yml and backend
# SUBGRAPH_URL=http://localhost:8000/subgraphs/name/realyx/1.0.0

# ============================================
# Frontend Build Args (docker-compose / Vercel)
# ============================================
# VITE_API_URL=/api
# VITE_WS_URL=ws://localhost:3000/ws
# VITE_WALLET_CONNECT_PROJECT_ID=
# VITE_TRADING_LIB_ADDRESS=0x5AEA00500f4b7519DeA151bC1590496ABAAb4B15
# VITE_POSITION_TOKEN_ADDRESS=0x0e7110ED111add8Ac5EB148567f4504569aC749f
# VITE_ORACLE_AGGREGATOR_ADDRESS=0xBb9B26F89624a505Fc4318463CC5a7325E5A106E
# VITE_VAULT_CORE_ADDRESS=0xe934aB1736a7924c1B9A290d57a73a0340092e24
# VITE_TRADING_CORE_ADDRESS=0x49493c04Df243FDD73a26E0AB10d9Fd89d82a92e

# ============================================
# Development & Testing
# ============================================

# Enable gas reporting
REPORT_GAS=false

# CoinMarketCap API for USD gas estimates
COINMARKETCAP_API_KEY=

# Skip confirmation prompts for mainnet deployment
# SKIP_CONFIRMATIONS=false

# Override gas price (gwei) for deploy/scripts if "replacement transaction underpriced"
# Example: GAS_PRICE_GWEI=25
# GAS_PRICE_GWEI=
