{
  "name": "realyx-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Realyx API and WebSocket backend (database indexer + RPC)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx watch src/worker.ts",
    "ws": "node dist/wsWorker.js",
    "ws:dev": "tsx watch src/wsWorker.ts",
    "test": "jest",
    "test:cov": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "pg": "^8.20.0",
    "pino": "^9.4.0",
    "pino-http": "^10.2.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.6.0",
    "jest": "^30.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
