# Server
PORT=3001
WS_PORT=3002
# Enable native WebSocket broadcaster (disable on Vercel serverless).
ENABLE_WS=true
# Enable on-chain active market filtering (recommended false on Vercel).
ENABLE_ACTIVE_MARKETS_FILTER=true
# Enable expensive per-market Pyth 24h-change lookups.
ENABLE_PYTH_24H=true

# Postgres Database Indexer
POSTGRES_URL=postgres://user:password@localhost:5432/realyx
# CRON_SECRET=super_secret_cron_string

# ── Security ──
# Comma-separated browser CORS allowlist. Leave unset to reflect any origin (dev only).
# CORS_ORIGINS=https://realyx.vercel.app,https://landing-realyx.vercel.app,https://docs-realyx.vercel.app
# Bearer secret the keeper-bot must present to POST /api/v1/keeper/failure.
# Required in production; if unset the endpoint is disabled in production.
# KEEPER_WEBHOOK_SECRET=
# Secret guarding /api/debug in production (sent as Authorization: Bearer <secret> or ?key=<secret>).
# If unset in production, /api/debug returns 404.
# DEBUG_SECRET=

# Chain (Conflux eSpace Testnet)
CHAIN_ID=71

# Optional: filter /api/markets to on-chain active markets only.
# If set, backend uses TradingCore.activeMarketCount() and filters database results.
# RPC_FALLBACK_URL is tried if RPC_URL fails.
# Primary + fallback (see also root CONFLUX_TESTNET_RPC_URL)
RPC_URL=https://evmtestnet.confluxrpc.com
RPC_FALLBACK_URL=https://evmtestnet.confluxrpc.org

# On-chain core (sync with deployment/<network>.json). Routes/sync also accept DEPLOYED_TRADING_CORE.
# deployment/confluxTestnet.json (2026-04-14)
TRADING_CORE_ADDRESS=0x64f277f73bfc81Ad80286a4266c0E0613d867Df3
VAULT_CORE_ADDRESS=0xB5C983d038caA21f4a9520b0EFAb2aD71DE4e714
ORACLE_AGGREGATOR_ADDRESS=0x89cC8eAbF2e967d81FD04D1023298A3bDcE67450

# Optional: ReferralRegistry for /api/referrals/stats (reads code, referees,
# and rebate balances on-chain). When unset, the referrals endpoint reports
# the program as not-live (no fabricated stats). Routes also accept
# DEPLOYED_REFERRAL_REGISTRY.
# REFERRAL_REGISTRY_ADDRESS=

NODE_ENV=development
METRICS_PORT=9090
