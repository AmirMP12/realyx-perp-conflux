# Server
PORT=3001
WS_PORT=3002
# Enable native WebSocket broadcaster (set false to use REST polling mode).
ENABLE_WS=true
# Enable on-chain active market filtering (adds RPC calls per request).
ENABLE_ACTIVE_MARKETS_FILTER=true
# Enable expensive per-market Pyth 24h-change lookups.
ENABLE_PYTH_24H=true

# Postgres Database Indexer (primary / writer)
POSTGRES_URL=postgres://user:password@localhost:5432/realyx
# Optional read replica for heavy aggregate reads (markets/stats/leaderboard/history).
# Writes always go to POSTGRES_URL; reads fall back to the primary when unset.
# Recommended topology for leader-grade reliability:
#   • a dedicated indexer worker (see below) writes to POSTGRES_URL
#   • the API tier reads from POSTGRES_READ_URL (a streaming replica)
# so a hot re-index never adds latency to user requests.
# POSTGRES_READ_URL=postgres://user:password@replica-host:5432/realyx

# ── Indexer / ingestion ──
# When a dedicated indexer worker (npm run worker) handles ingestion, set this
# on the API process so it stops running the in-band sync loop and becomes a
# pure reader. Ingestion is serialized cluster-wide by a Postgres advisory lock,
# so leaving both on is safe — this just avoids redundant scans.
# DISABLE_INBAND_SYNC=true
# Indexer worker poll cadence (ms). Lower = fresher data, more RPC load.
# INDEXER_INTERVAL_MS=5000
# Reorg handling: precise block-hash checkpointing walks back to the common
# ancestor on a reorg. These bound the fallback rewind and how many recent
# block hashes are retained for that walk-back.
# INDEXER_REORG_BUFFER=64
# INDEXER_BLOCK_HASH_RETENTION=512
# getLogs window bounds (adaptive: halves on RPC failure, grows back on success).
# INDEXER_MAX_CHUNK=50000
# INDEXER_MIN_CHUNK=1000
# CRON_SECRET=super_secret_cron_string

# ── Data-quality reconciliation ──
# Periodically compares indexed aggregates (open interest) and TVL against
# authoritative on-chain reads, publishing realyx_reconciliation_drift_ratio so
# a silent indexer bug trips an alert before users see wrong numbers.
# RECONCILE_INTERVAL_MS=300000
# DISABLE_RECONCILIATION=true

# ── RPC pool circuit breaker ──
# Per-endpoint failover with circuit breaking across the RPC pool.
# Consecutive failures before an endpoint trips OPEN (skipped while cooling):
# RPC_FAILURE_THRESHOLD=3
# Base cooldown before a tripped endpoint gets a half-open trial (ms):
# RPC_COOLDOWN_MS=30000
# Cap on the exponential cooldown backoff for a repeatedly-failing endpoint (ms):
# RPC_MAX_COOLDOWN_MS=300000

# ── Cache ──
# Optional Redis for the shared response cache (markets/stats hot paths), shared
# across replicas. Requires the optional `ioredis` dependency. When unset (or
# ioredis is not installed) an in-process LRU+TTL cache is used instead.
# REDIS_URL=redis://localhost:6379

# ── Security ──
# Comma-separated browser CORS allowlist. Leave unset to reflect any origin (dev only).
# CORS_ORIGINS=https://your-frontend.up.railway.app
# Bearer secret the keeper-bot must present to POST /api/v1/keeper/failure.
# Required in production; if unset the endpoint is disabled in production.
# KEEPER_WEBHOOK_SECRET=
# Secret guarding /api/debug in production (sent as Authorization: Bearer <secret> or ?key=<secret>).
# If unset in production, /api/debug returns 404.
# DEBUG_SECRET=

# Chain (Conflux eSpace Testnet)
CHAIN_ID=71

# Optional: filter /api/markets to on-chain active markets only.
# If set, backend uses TradingCore.activeMarketCount() and filters database results.
# All RPC endpoints below form a health-routed pool with automatic failover.
# Primary + fallback (see also root CONFLUX_TESTNET_RPC_URL)
RPC_URL=https://evmtestnet.confluxrpc.com
RPC_FALLBACK_URL=https://evmtestnet.confluxrpc.org
# Alternatively, define an explicit comma-separated RPC pool (takes precedence in ordering):
# RPC_URLS=https://evmtestnet.confluxrpc.com,https://evmtestnet.confluxrpc.org

# On-chain core (sync with deployment/<network>.json). Routes/sync also accept DEPLOYED_TRADING_CORE.
# deployment/confluxTestnet.json (2026-06-21)
TRADING_CORE_ADDRESS=0xc8A6585dFBe2833ed093E557D36DC8Fe136a8c76
VAULT_CORE_ADDRESS=0x98E011A8782aF36C5Ad6051bC54B86a7c0705F67
ORACLE_AGGREGATOR_ADDRESS=0x9d027ab66F396176C188946cE49BA9061679e6a9

# Optional: ReferralRegistry for /api/referrals/stats (reads code, referees,
# and rebate balances on-chain). When unset, the referrals endpoint reports
# the program as not-live (no fabricated stats). Routes also accept
# DEPLOYED_REFERRAL_REGISTRY.
REFERRAL_REGISTRY_ADDRESS=0x5FbD3aBfBdB667e543B23B80f34Fa7167C1514a8

NODE_ENV=development
METRICS_PORT=9090
