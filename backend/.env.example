# Server
PORT=3001
WS_PORT=3002

# Subgraph (Realyx public Conflux subgraph)
# TheGraph Subgraph URL (Studio or local)
SUBGRAPH_URL=https://api.studio.thegraph.com/query/1741472/realyx/1.0.0
# SUBGRAPH_URL=http://graph-node:8000/subgraphs/name/realyx

# Chain (Conflux eSpace Testnet)
CHAIN_ID=71

# Optional: filter /api/markets to on-chain active markets only.
# If set, backend uses TradingCore.activeMarketCount() and filters subgraph results.
# RPC_FALLBACK_URL is tried if RPC_URL fails.
RPC_URL=https://evmtestnet.confluxrpc.com
RPC_FALLBACK_URL=https://evmtestnet.confluxrpc.com
TRADING_CORE_ADDRESS=0xDDe4D077C617C1B84dA369fB8fD391BE6530C40E
ORACLE_AGGREGATOR_ADDRESS=0x8190715C58f4d1be1a1EF8FdA44133B77972e9e1

NODE_ENV=development
METRICS_PORT=9090
