{
  "name": "realyx-subgraph",
  "version": "1.0.0",
  "description": "Realyx subgraph - index contract events",
  "scripts": {
    "codegen": "graph codegen && node scripts/fix-generated-types.js",
    "build": "graph build",
    "clean": "rimraf build/ generated/",
    "auth:studio": "graph auth --studio",
    "create:local": "graph create --node http://127.0.0.1:8020/ realyx/1.0.0",
    "remove:local": "graph remove --node http://127.0.0.1:8020/ realyx/1.0.0",
    "deploy:local": "graph deploy --node http://127.0.0.1:8020/ --ipfs http://127.0.0.1:5001 realyx/1.0.0",
    "deploy:studio": "node scripts/deploy-studio.js"
  },
  "dependencies": {
    "@graphprotocol/graph-ts": "0.35.0"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "0.68.0",
    "source-map-support": "^0.5.21"
  },
  "engines": {
    "node": ">=18"
  }
}
