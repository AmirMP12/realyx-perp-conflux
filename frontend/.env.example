# Backend (local dev; docker/nginx often uses VITE_API_URL=/api and same-origin WS)
VITE_API_URL=http://localhost:3001/api
# Leave empty to use REST polling mode (recommended on Railway single-port services).
VITE_WS_URL=
# Local/backend deployment only:
# VITE_WS_URL=ws://localhost:3002

# Optional: WalletConnect / app metadata base URL (defaults to window.location.origin in dev)
# VITE_APP_URL=http://localhost:5173

# Network (Conflux eSpace Testnet) — primary RPC; wagmi adds https://evmtestnet.confluxrpc.org as fallback
VITE_CHAIN_ID=71
VITE_RPC_URL=https://evmtestnet.confluxrpc.com
VITE_CONFLUX_TESTNET_RPC_URL=https://evmtestnet.confluxrpc.com
# https://cloud.walletconnect.com
VITE_WALLET_CONNECT_PROJECT_ID=3a8170812b534d0ff9d794f19a901d64

# Pyth Hermes endpoint used by the in-app on-chain price updater
# (usePythOnChainUpdater). Defaults to the public Hermes if unset.
VITE_HERMES_URL=https://hermes.pyth.network

# Contract addresses — sync with deployment/confluxTestnet.json (2026-06-21)
VITE_TRADING_CORE_ADDRESS=0xc8A6585dFBe2833ed093E557D36DC8Fe136a8c76
VITE_VAULT_CORE_ADDRESS=0x98E011A8782aF36C5Ad6051bC54B86a7c0705F67
VITE_ORACLE_AGGREGATOR_ADDRESS=0x9d027ab66F396176C188946cE49BA9061679e6a9
VITE_POSITION_TOKEN_ADDRESS=0xF520CC4B305553A9b6D391571c303E45AacC178c
VITE_MOCK_USDT0_ADDRESS=0x85B9BA60D6Aef728c0Ea9C9f6709D31707dfC73A

# Multi-collateral / social trading registries (set after deploy)
VITE_COLLATERAL_REGISTRY_ADDRESS=0x0f5cAC8a3BC4E61ABA1d547D9A2C1DFA5A087054
# Set to "true" only when the deployed TradingCore accepts non-USDC collateral
# on createOrder. While false (default), the trading UI shows registered alt
# collateral (haircuts, balances, exposure) but settles orders in USDC.
VITE_MULTI_COLLATERAL_ORDERS_ENABLED=false
VITE_COPY_REGISTRY_ADDRESS=0xf09b2fa210Fe2dbE17287B331E7A93c58Bb5A001
VITE_REFERRAL_REGISTRY_ADDRESS=0x5FbD3aBfBdB667e543B23B80f34Fa7167C1514a8
# CopyBot EOA that mirrors lead-trader orders (used by CopyModal)
VITE_COPY_BOT_ADDRESS=
# USDT0 token used for copy-trading allocations (defaults to mock USDT0 on testnet)
VITE_USDT0_ADDRESS=0x85B9BA60D6Aef728c0Ea9C9f6709D31707dfC73A

# Off-app push notifications (PWA). VAPID public key for Web Push; leave empty
# to fall back to in-app + local Notification API alerts only (subscribeToPush
# is a no-op without it).
VITE_VAPID_PUBLIC_KEY=

# Development
VITE_MOCK_MODE=false
